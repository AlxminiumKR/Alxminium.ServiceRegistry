<Window x:Class="Alxminium.ServiceRegistry.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация — ServiceRegistry" Height="350" Width="450" 
        WindowStartupLocation="CenterScreen" Background="#F0F2F5"
        ResizeMode="NoResize">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="ВХОД В СИСТЕМУ" FontSize="20" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,30" Foreground="#333"/>

            <TextBlock Text="Логин" Margin="0,0,0,5" Foreground="#666"/>
            <TextBox x:Name="TxtLogin" Height="35" VerticalContentAlignment="Center" Padding="5,0"/>

            <TextBlock Text="Пароль" Margin="0,15,0,5" Foreground="#666"/>
            <PasswordBox x:Name="TxtPassword" Height="35" VerticalContentAlignment="Center" Padding="5,0"/>

            <Button x:Name="BtnLogin" Content="Войти" Margin="0,30,0,0" Height="40" 
                    Background="#2196F3" Foreground="White" FontWeight="Bold"
                    Click="BtnLogin_Click" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>