<Window x:Class="Alxminium.ServiceRegistry.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Авторизация - alxminium" Height="480" Width="380" 
        WindowStartupLocation="CenterScreen" Background="#F5F5F5"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        FocusManager.FocusedElement="{Binding ElementName=TxtLogin}"
        PreviewKeyDown="Window_PreviewKeyDown"
        Icon="Models/EmblemSR.png">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <materialDesign:ColorZone Mode="PrimaryMid" Padding="20" materialDesign:ElevationAssist.Elevation="Dp4">
            <TextBlock HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Text="SERVICE REGISTRY"/>
        </materialDesign:ColorZone>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="30">
            <materialDesign:PackIcon Kind="AccountLock" Foreground="{DynamicResource PrimaryHueMidBrush}" 
                                     Width="50" Height="50" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBox x:Name="TxtLogin" 
                     materialDesign:HintAssist.Hint="Логин" 
                     materialDesign:HintAssist.HelperText="Введите имя пользователя"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                     FontSize="16" Margin="0,0,0,20"/>

            <Grid Margin="0,0,0,30">
                <PasswordBox x:Name="TxtPassword" 
                             materialDesign:HintAssist.Hint="Пароль" 
                             materialDesign:HintAssist.HelperText="Ваш секретный код"
                             Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" 
                             FontSize="16"
                             GotFocus="TxtPassword_GotFocus"
                             LostFocus="TxtPassword_LostFocus"/>

                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Margin="0,0,5,15"
                            IsHitTestVisible="False">

                    <materialDesign:PackIcon x:Name="IconCaps" 
                                             Kind="ArrowUpBoldBox" 
                                             Foreground="OrangeRed" 
                                             Width="18" Height="18" 
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0"
                                             Visibility="Collapsed"/>

                    <TextBlock x:Name="TxtLang" 
                               Text="EN" 
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                               FontWeight="Bold"
                               Opacity="0.7"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Grid>

            <Button x:Name="BtnLogin" 
                    Content="ВОЙТИ В СИСТЕМУ" 
                    Click="BtnLogin_Click" 
                    IsDefault="True"  Style="{StaticResource MaterialDesignRaisedButton}" 
                    Height="50" 
                    materialDesign:ButtonAssist.CornerRadius="25"/>
        </StackPanel>
    </Grid>
</Window>