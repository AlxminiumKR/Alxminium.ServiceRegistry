<Window x:Class="Alxminium.ServiceRegistry.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Система учета заявок — alxminium" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Icon="Models/EmblemSR.png">

    <Window.Resources>
        <Style x:Key="WrapTextColumnStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="WrapHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" 
                                   TextWrapping="Wrap" 
                                   TextAlignment="Left" 
                                   MaxHeight="40"
                                   FontWeight="Bold"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HelpCardStyle" TargetType="materialDesign:Card">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Width" Value="350"/>
            <Setter Property="Height" Value="220"/>
            <Setter Property="UniformCornerRadius" Value="15"/>
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2"/>
        </Style>
    </Window.Resources>

    <Grid>
        <materialDesign:DialogHost x:Name="FeedbackDialog" Identifier="RootDialog">
            <materialDesign:DialogHost.DialogContent>
                <StackPanel Margin="24" Width="350">
                    <TextBlock Text="ОБРАТНАЯ СВЯЗЬ" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,8"/>
                    <TextBlock Text="Опишите проблему или предложите идею. Сообщение будет мгновенно отправлено разработчику в Telegram." 
                               Style="{StaticResource MaterialDesignBody2TextBlock}" TextWrapping="Wrap" Margin="0,0,0,20" Foreground="#757575"/>

                    <TextBox x:Name="TxtFeedbackMessage" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="120" materialDesign:HintAssist.Hint="Ваше сообщение..." 
                             materialDesign:TextFieldAssist.HasClearButton="True"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="ОТМЕНА" Click="BtnCloseFeedback_Click" 
                                Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,8,0"/>
                        <Grid>
                            <Button x:Name="BtnSendFeedback" Content="ОТПРАВИТЬ" 
                                    Click="BtnSendFeedback_Click" 
                                    Style="{StaticResource MaterialDesignRaisedButton}"/>
                            <ProgressBar x:Name="FeedbackProgress" 
                                         Style="{StaticResource MaterialDesignCircularProgressBar}" 
                                         Value="0" IsIndeterminate="True" 
                                         Visibility="Collapsed" 
                                         Width="24" Height="24" 
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </materialDesign:DialogHost.DialogContent>

            <DockPanel>
                <materialDesign:ColorZone Mode="PrimaryMid" Padding="16" DockPanel.Dock="Top" materialDesign:ElevationAssist.Elevation="Dp4">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" Width="24" Height="24" VerticalAlignment="Center"/>
                            <TextBlock Margin="16,0,0,0" FontSize="20" FontWeight="Bold" Text="SERVICE REGISTRY" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="dev: alxminium" HorizontalAlignment="Right" VerticalAlignment="Center" 
                                   Foreground="#BDBDBD" FontSize="12" FontStyle="Italic"/>
                    </DockPanel>
                </materialDesign:ColorZone>

                <StatusBar DockPanel.Dock="Bottom" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                    <StatusBarItem>
                        <StackPanel Orientation="Horizontal" Margin="10,2">
                            <materialDesign:PackIcon Kind="ChartBar" VerticalAlignment="Center" Foreground="#757575"/>
                            <TextBlock Text="Всего заявок: " Margin="8,0,0,0" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtTotalCount" Text="0"/>
                            <Separator Margin="16,0" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
                            <materialDesign:PackIcon Kind="ClockOutline" VerticalAlignment="Center" Foreground="#FFA000"/>
                            <TextBlock Text=" В работе: " Margin="4,0,0,0" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtPendingCount" Text="0"/>
                            <Separator Margin="16,0" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
                            <materialDesign:PackIcon Kind="CheckCircleOutline" VerticalAlignment="Center" Foreground="Green"/>
                            <TextBlock Text=" Выполнено: " Margin="4,0,0,0" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtCompletedCount" Text="0"/>
                        </StackPanel>
                    </StatusBarItem>
                </StatusBar>

                <TabControl x:Name="MainTabControl" 
                            materialDesign:ColorZoneAssist.Mode="PrimaryMid"
                            Style="{StaticResource MaterialDesignNavigationRailTabControl}">

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Width="72">
                                <materialDesign:PackIcon Kind="PlusCircle" Foreground="White" HorizontalAlignment="Center" Width="24" Height="24"/>
                                <TextBlock Text="РЕГИСТРАЦИЯ" FontSize="10" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <materialDesign:Card Margin="40" Padding="32" MaxWidth="500" HorizontalAlignment="Left" VerticalAlignment="Top" 
                                                 UniformCornerRadius="10" materialDesign:ElevationAssist.Elevation="Dp3">
                                <StackPanel>
                                    <TextBlock Text="Новая заявка" Style="{StaticResource MaterialDesignHeadline5TextBlock}" Margin="0,0,0,24"/>
                                    <ComboBox x:Name="ComboObjects" materialDesign:HintAssist.Hint="Выберите объект обслуживания" 
                                              Style="{StaticResource MaterialDesignFloatingHintComboBox}" 
                                              DisplayMemberPath="Name" Margin="0,0,0,20"/>
                                    <ComboBox x:Name="ComboServices" materialDesign:HintAssist.Hint="Тип работы / Услуга" 
                                              Style="{StaticResource MaterialDesignFloatingHintComboBox}" 
                                              DisplayMemberPath="WorkName" Margin="0,0,0,20"/>
                                    <TextBox x:Name="TxtVolume" materialDesign:HintAssist.Hint="Объем работ (количество)" 
                                              Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,20"/>
                                    <TextBox x:Name="TxtDescription" 
                                              materialDesign:HintAssist.Hint="Описание проблемы / Комментарий" 
                                              Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                              TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" 
                                              MinHeight="80" Margin="0,0,0,32"/>
                                    <Button x:Name="BtnCreateRequest" Content="СОЗДАТЬ ЗАЯВКУ" Click="BtnCreateRequest_Click" 
                                            Height="50" materialDesign:ButtonAssist.CornerRadius="25"
                                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                                </StackPanel>
                            </materialDesign:Card>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem x:Name="TabArchive">
                        <TabItem.Header>
                            <StackPanel Width="72">
                                <materialDesign:PackIcon Kind="FileTable" Foreground="White" HorizontalAlignment="Center" Width="24" Height="24"/>
                                <TextBlock Text="АРХИВ" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </TabItem.Header>
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <materialDesign:Card Padding="12" Margin="0,0,0,20" materialDesign:ElevationAssist.Elevation="Dp1">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox x:Name="ChkShowCompleted" Checked="Filter_Changed" Unchecked="Filter_Changed" 
                                              Content="Показать выполненные" VerticalAlignment="Center" Margin="0,0,24,0"/>
                                    <materialDesign:PackIcon Kind="Magnify" VerticalAlignment="Bottom" Margin="0,0,4,8" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                    <TextBox x:Name="TxtSearch" materialDesign:HintAssist.Hint="Поиск по объекту или услуге" 
                                             Width="220" Margin="0,0,24,0" 
                                             TextChanged="TxtSearch_TextChanged"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                                    <DatePicker x:Name="DateFrom" materialDesign:HintAssist.Hint="Дата С" Width="100" Margin="0,0,8,0" Style="{StaticResource MaterialDesignFloatingHintDatePicker}"/>
                                    <TextBlock Text="—" VerticalAlignment="Bottom" Margin="0,0,8,8"/>
                                    <DatePicker x:Name="DateTo" materialDesign:HintAssist.Hint="Дата ПО" Width="100" Margin="0,0,24,0" Style="{StaticResource MaterialDesignFloatingHintDatePicker}"/>
                                    <Button Click="BtnExport_Click" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#2E7D32" Padding="8,4">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="FileExcel" Width="20" Height="20" VerticalAlignment="Center"/>
                                            <TextBlock Text="ЭКСПОРТ EXCEL" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </materialDesign:Card>

                            <materialDesign:Card Grid.Row="1" materialDesign:ElevationAssist.Elevation="Dp2">
                                <DataGrid x:Name="GridRequests" MouseDoubleClick="GridRequests_MouseDoubleClick" 
                                          AutoGenerateColumns="False" IsReadOnly="True" ItemsSource="{Binding}" 
                                          CanUserAddRows="False" SelectionMode="Single"
                                          Style="{StaticResource MaterialDesignDataGrid}"
                                          ColumnHeaderStyle="{StaticResource WrapHeaderStyle}">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Редактировать" Click="MenuEditRequest_Click">
                                                <MenuItem.Icon>
                                                    <materialDesign:PackIcon Kind="Pencil" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="Удалить заявку" Click="BtnDeleteRequest_Click" Foreground="#E53935">
                                                <MenuItem.Icon>
                                                    <materialDesign:PackIcon Kind="Delete" Foreground="#E53935" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy'}" Width="100"/>
                                        <DataGridTextColumn Header="Объект" Binding="{Binding ObjectName}" Width="150" ElementStyle="{StaticResource WrapTextColumnStyle}"/>
                                        <DataGridTextColumn Header="Работа" Binding="{Binding WorkName}" Width="150" ElementStyle="{StaticResource WrapTextColumnStyle}"/>
                                        <DataGridTextColumn Header="Срок (дн)" Binding="{Binding DeadlineDays}" Width="80"/>
                                        <DataGridTextColumn Header="Объем" Binding="{Binding Volume}" Width="80"/>
                                        <DataGridTextColumn Header="Сумма" Binding="{Binding TotalCost, StringFormat='{}{0:N2} ₽'}" Width="100"/>
                                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="110">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource WrapTextColumnStyle}">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="Text" Value="Выполнена">
                                                            <Setter Property="Foreground" Value="Green"/>
                                                        </Trigger>
                                                        <Trigger Property="Text" Value="В работе">
                                                            <Setter Property="Foreground" Value="#FFA000"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*" MinWidth="150" ElementStyle="{StaticResource WrapTextColumnStyle}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </materialDesign:Card>
                        </Grid>
                    </TabItem>

                    <TabItem x:Name="TabAdmin" Visibility="Hidden" IsEnabled="False">
                        <TabItem.Header>
                            <StackPanel Width="72">
                                <materialDesign:PackIcon Foreground="White" Kind="Settings" HorizontalAlignment="Center" Width="24" Height="24"/>
                                <TextBlock Text="АДМИН" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </TabItem.Header>
                        <UniformGrid Columns="2" Margin="10">
                            <materialDesign:Card Margin="10" Padding="15">
                                <DockPanel>
                                    <TextBlock Text="РЕЕСТР ОБЪЕКТОВ" DockPanel.Dock="Top" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,10"/>
                                    <Button Content="ИМПОРТ ИЗ EXCEL" Click="BtnImportObjects_Click" DockPanel.Dock="Bottom" Margin="0,15,0,0" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                    <DataGrid x:Name="GridAllObjects" AutoGenerateColumns="False" IsReadOnly="True" 
                                              Style="{StaticResource MaterialDesignDataGrid}"
                                              ColumnHeaderStyle="{StaticResource WrapHeaderStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="120" ElementStyle="{StaticResource WrapTextColumnStyle}"/>
                                            <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="*" MinWidth="100" ElementStyle="{StaticResource WrapTextColumnStyle}"/>
                                            <DataGridTextColumn Header="Ответственный" Binding="{Binding ResponsiblePerson}" Width="120" ElementStyle="{StaticResource WrapTextColumnStyle}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </materialDesign:Card>

                            <materialDesign:Card Margin="10" Padding="15">
                                <DockPanel>
                                    <TextBlock Text="СПИСОК УСЛУГ" DockPanel.Dock="Top" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,10"/>
                                    <Button Content="ИМПОРТ ИЗ EXCEL" Click="BtnImportServices_Click" DockPanel.Dock="Bottom" Margin="0,15,0,0" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                    <DataGrid x:Name="GridAllServices" AutoGenerateColumns="False" IsReadOnly="True" 
                                              Style="{StaticResource MaterialDesignDataGrid}"
                                              ColumnHeaderStyle="{StaticResource WrapHeaderStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Категория" Binding="{Binding WorkType}" Width="100" ElementStyle="{StaticResource WrapTextColumnStyle}"/>
                                            <DataGridTextColumn Header="Услуга" Binding="{Binding WorkName}" Width="120" ElementStyle="{StaticResource WrapTextColumnStyle}"/>
                                            <DataGridTemplateColumn Header="Описание" Width="*" MinWidth="150">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Padding="5" VerticalAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat='{}{0:N2} ₽'}" Width="100"/>
                                            <DataGridTextColumn Header="Срок (дн)" Binding="{Binding DeadlineDays}" Width="80"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </materialDesign:Card>
                        </UniformGrid>
                    </TabItem>

                    <!-- Эта часть просто для того, чтобы опустить кнопку "Справка" в самый низ, так как я честно не хочу запарываться с тем, чтобы её опускать вниз, поэтому здесь костыли. -->
                    <TabItem IsEnabled="False">
                        <TabItem.Header>
                            <Grid Height="50" />
                        </TabItem.Header>
                    </TabItem>
                    <TabItem IsEnabled="False">
                        <TabItem.Header>
                            <Grid Height="50" />
                        </TabItem.Header>
                    </TabItem>
                    <TabItem IsEnabled="False">
                        <TabItem.Header>
                            <Grid Height="50" />
                        </TabItem.Header>
                    </TabItem>
                    <TabItem IsEnabled="False">
                        <TabItem.Header>
                            <Grid Height="50" />
                        </TabItem.Header>
                    </TabItem>
                    <TabItem IsEnabled="False">
                        <TabItem.Header>
                            <Grid Height="50" />
                        </TabItem.Header>
                    </TabItem>
                    <!-- Эта часть просто для того, чтобы опустить кнопку "Справка" в самый низ, так как я честно не хочу запарываться с тем, чтобы её опускать вниз, поэтому здесь костыли. -->

                    <TabItem x:Name="TabHelp">
                        <TabItem.Header>
                            <StackPanel Width="72">
                                <materialDesign:PackIcon Foreground="#FFE082" Kind="HelpCircle" HorizontalAlignment="Center" Width="24" Height="24"/>
                                <TextBlock Text="СПРАВКА" Foreground="#FFE082" FontSize="10" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer>
                            <StackPanel Margin="30">
                                <TextBlock Text="РУКОВОДСТВО ПОЛЬЗОВАТЕЛЯ" Style="{StaticResource MaterialDesignHeadline4TextBlock}" Margin="10,0,0,20"/>

                                <WrapPanel Orientation="Horizontal">
                                    <materialDesign:Card Style="{StaticResource HelpCardStyle}">
                                        <StackPanel>
                                            <materialDesign:PackIcon Kind="Briefcase" Width="32" Height="32" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                            <TextBlock Text="Процесс работы" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,10,0,5"/>
                                            <TextBlock Text="1. Выберите объект и услугу.&#x0a;2. Укажите объем работ.&#x0a;3. Опишите проблему/уточняющий комментарий &#x0a;4. Создайте заявку." 
                                                       TextWrapping="Wrap" Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                                        </StackPanel>
                                    </materialDesign:Card>

                                    <materialDesign:Card Style="{StaticResource HelpCardStyle}">
                                        <Grid Margin="0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0">
                                                <materialDesign:PackIcon Kind="FileExcel" Width="32" Height="32" Foreground="Green"/>
                                                <TextBlock Text="Excel: Объекты" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,10,0,5"/>
                                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MaterialDesignBody2TextBlock}">
                                                <Run Text="Столбцы: name, address, responsible."/>
                                                <LineBreak/>
                                                <Run Text="ID указывать не нужно. Первая строка - заголовок. Система создаст ID автоматически."/>
                                                </TextBlock>
                                            </StackPanel>

                                            <Button Grid.Row="1" 
                Style="{StaticResource MaterialDesignFlatButton}"
                Click="BtnDownloadObjectsTemplate_Click"
                HorizontalAlignment="Stretch"
                Foreground="{DynamicResource PrimaryHueMidBrush}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Download" Margin="0,0,8,0" Width="18" Height="18"/>
                                                    <TextBlock Text="СКАЧАТЬ ШАБЛОН"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </materialDesign:Card>

                                    <materialDesign:Card Style="{StaticResource HelpCardStyle}">
                                        <Grid Margin="0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0">
                                                <materialDesign:PackIcon Kind="ListBoxOutline" Width="32" Height="32" Foreground="Orange"/>
                                                <TextBlock Text="Excel: Услуги" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,10,0,5"/>
                                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MaterialDesignBody2TextBlock}">
                                                <Run Text="Столбцы: work_name, work_type, description, unit, price, deadline_days."/>
                                                <LineBreak/>
                                                <Run Text="Цена и срок - числа. В ед. изм. укажите 'шт.', 'усл.' или 'м.'"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <Button Grid.Row="1" 
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    Click="BtnDownloadServicesTemplate_Click"
                                                    HorizontalAlignment="Stretch"
                                                    Foreground="{DynamicResource PrimaryHueMidBrush}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Download" Margin="0,0,8,0" Width="18" Height="18"/>
                                                    <TextBlock Text="СКАЧАТЬ ШАБЛОН"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </materialDesign:Card>

                                    <materialDesign:Card Style="{StaticResource HelpCardStyle}">
                                        <StackPanel>
                                            <materialDesign:PackIcon Kind="StateMachine" Width="32" Height="32" Foreground="DodgerBlue"/>
                                            <TextBlock Text="Управление статусами" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,10,0,5"/>
                                            <TextBlock Text="Двойной клик по заявке задаёт ей статус 'Выполнено'. Клик правой кнопкой мыши открывает окно редактирования, где можно редактировать выбранную заявку или удалить её." 
                                                       TextWrapping="Wrap" Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                                        </StackPanel>
                                    </materialDesign:Card>
                                </WrapPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
            </DockPanel>
        </materialDesign:DialogHost>

        <Button Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,28,80" Background="#673AB7" BorderBrush="#673AB7"
                Click="BtnOpenFeedback_Click">
            <materialDesign:PackIcon Kind="MessageReplyText" Width="22" Height="22" />
        </Button>
        <materialDesign:Snackbar x:Name="MainSnackbar" 
                         MessageQueue="{materialDesign:MessageQueue}" 
                         Background="#673AB7" 
                         Foreground="White"
                         VerticalAlignment="Bottom" 
                         HorizontalAlignment="Center"
                         Margin="0,0,0,24">
            <materialDesign:Snackbar.ActionButtonStyle>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="12,0,12,0"/>
                    <Setter Property="Margin" Value="16,1,8,0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.7"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </materialDesign:Snackbar.ActionButtonStyle>
        </materialDesign:Snackbar>
        <Grid x:Name="WelcomeOverlay" Background="#3f51b5" Opacity="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <materialDesign:Card UniformCornerRadius="25" 
                             materialDesign:ElevationAssist.Elevation="Dp12"
                             Background="White"
                             Width="380"
                             Margin="0,0,0,40">

                    <Grid Width="300" Height="300" HorizontalAlignment="Center">
                        <Image Source="/Models/EmblemSR.png" 
                       Stretch="Uniform"
                       Margin="20"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Effect>
                                <DropShadowEffect BlurRadius="15" Direction="270" Opacity="0.1" ShadowDepth="3"/>
                            </Image.Effect>
                        </Image>
                    </Grid>
                </materialDesign:Card>

                <TextBlock Text="ДОБРО ПОЖАЛОВАТЬ" 
                   Style="{StaticResource MaterialDesignHeadline3TextBlock}" 
                   Foreground="White"
                   FontWeight="Light"
                   HorizontalAlignment="Center"/>

                <TextBlock x:Name="TxtWelcomeUser" Text="Загрузка профиля..." 
                   HorizontalAlignment="Center" 
                   Margin="0,15,0,0"
                   Foreground="#E0E0E0"
                   Style="{StaticResource MaterialDesignBody1TextBlock}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>