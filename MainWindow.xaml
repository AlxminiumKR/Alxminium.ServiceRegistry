<Window x:Class="Alxminium.ServiceRegistry.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Система учета заявок — alxminium" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <TabControl>
            <TabItem Header="Регистрация">
                <StackPanel Margin="20" MaxWidth="500" HorizontalAlignment="Left">
                    <TextBlock Text="Новая заявка" FontSize="20" Margin="0,0,0,20" FontWeight="Bold"/>

                    <TextBlock Text="Выберите объект:"/>
                    <ComboBox x:Name="ComboObjects" DisplayMemberPath="Name" Margin="0,5,0,15"/>
                    <TextBlock Text="Выберите услугу:"/>
                    <ComboBox x:Name="ComboServices" DisplayMemberPath="WorkName" Margin="0,5,0,15"/>
                    <TextBlock Text="Объем работ (кол-во):"/>
                    <TextBox x:Name="TxtVolume" Margin="0,5,0,20"/>
                    <Button Content="Создать заявку" Height="40" Background="#2196F3" Foreground="White" Click="BtnCreateRequest_Click"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Архив заявок">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <CheckBox x:Name="ChkShowCompleted" Checked="Filter_Changed" Unchecked="Filter_Changed" Content="Отображать выполненные заявки" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <DatePicker x:Name="DateFrom" Margin="5,0"/>
                        <TextBlock Text="—" VerticalAlignment="Center"/>
                        <DatePicker x:Name="DateTo" Margin="5,0"/>
                        <Button Content="Экспорт в Excel" Click="BtnExport_Click" Margin="20,0,0,0" Padding="10,2"/>
                        <Button x:Name="BtnDeleteRequest" Content="Удалить заявку" Click="BtnDeleteRequest_Click" Margin="5" Background="#FFD32F2F" Foreground="White"/>
                    </StackPanel>

                    <DataGrid x:Name="GridRequests" MouseDoubleClick="GridRequests_MouseDoubleClick" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat='dd/MM/yy'}"/>
                            <DataGridTextColumn Header="Объект" Binding="{Binding ObjectName}"/>
                            <DataGridTextColumn Header="Работа" Binding="{Binding WorkName}"/>
                            <DataGridTextColumn Header="Объем" Binding="{Binding Volume}"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Администрирование">
                <UniformGrid Columns="2" Margin="10">
                    <GroupBox Header="Реестр объектов">
                        <DockPanel>
                            <Button Content="Импорт объектов (.xlsx)" Click="BtnImportObjects_Click" DockPanel.Dock="Top" Margin="5"/>
                            <DataGrid x:Name="GridAllObjects"/>
                        </DockPanel>
                    </GroupBox>
                    <GroupBox Header="Список услуг">
                        <DockPanel>
                            <Button Content="Импорт услуг (.xlsx)" Click="BtnImportServices_Click" DockPanel.Dock="Top" Margin="5"/>
                            <DataGrid x:Name="GridAllServices"/>
                        </DockPanel>
                    </GroupBox>
                </UniformGrid>
            </TabItem>
        </TabControl>

        <TextBlock Text="dev: alxminium" HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                   Margin="5" Foreground="Gray" FontSize="10"/>
    </Grid>
</Window>